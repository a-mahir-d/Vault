<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vault.MainWindow"
        Title="Vault - Security Hub" 
        Width="450" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"> 
    
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="25">
            
            <TextBlock Text="VAULT"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="#E0E0E0"
                       HorizontalAlignment="Center"
                       LetterSpacing="5"
                       Margin="0,0,0,10"/>

            <Button Name="BtnPasswordVault"
                    Content="Password Vault"
                    Width="250" Height="55"
                    FontSize="18"
                    CornerRadius="8"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnVaultSelected"/>

            <Button Name="BtnFileVault"
                    Content="File Vault"
                    Width="250" Height="55"
                    FontSize="18"
                    CornerRadius="8"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnVaultSelected"/>
                    
            <TextBlock Name="TxtStatusMessage" 
                       Foreground="#FF5555" 
                       FontSize="14" 
                       HorizontalAlignment="Center" 
                       Margin="0,10,0,0"
                       FontWeight="SemiBold"
                       IsVisible="False"/>

            <ProgressBar Name="MainProgressLoader" 
                         IsIndeterminate="True" 
                         Width="200" 
                         Margin="0,5,0,0"
                         HorizontalAlignment="Center"
                         IsVisible="False"/>
            
        </StackPanel>
    </Grid>
</Window>