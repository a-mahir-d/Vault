<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vault.PasswordEditWindow"
        Title="Şifre Kaydı"
        Width="450" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White">
    
    <Grid Margin="25" RowDefinitions="*, Auto">
        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <StackPanel Spacing="15">
                
                <TextBlock Name="LblTitle" Text="Şifre Kaydı" FontSize="18" FontWeight="Bold" Foreground="#2A7AD2" Margin="0,0,0,10"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="Site / Uygulama Adı" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Name="TxtSite" PlaceholderText="Örn: github.com" Background="#2D2D2D" Foreground="White" BorderBrush="#444444" CornerRadius="4"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="E-Posta Adresi" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Name="TxtEmail" PlaceholderText="Örn: isim@mail.com" Background="#2D2D2D" Foreground="White" BorderBrush="#444444" CornerRadius="4"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Kullanıcı Adı" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Name="TxtUsername" PlaceholderText="Örn: siber_uzman" Background="#2D2D2D" Foreground="White" BorderBrush="#444444" CornerRadius="4"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Şifre" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Name="TxtPassword" PasswordChar="•" PlaceholderText="Güçlü bir şifre girin" Background="#2D2D2D" Foreground="White" BorderBrush="#444444" CornerRadius="4"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Kurtarma Kodları" Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>
                    
                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                        <TextBox Name="TxtNewCode" 
                                 Grid.Column="0" 
                                 PlaceholderText="Yeni kurtarma kodu yaz..." 
                                 Background="#2D2D2D" 
                                 Foreground="White" 
                                 BorderBrush="#444444" 
                                 CornerRadius="4,0,0,4"/>
    
                        <Button Name="BtnAddCode" 
                                Content="Ekle" 
                                Grid.Column="1" 
                                Background="#333333" 
                                Padding="15,0" 
                                Height="32" 
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                CornerRadius="0,4,4,0" 
                                Click="OnAddCodeClick"/>
                    </Grid>
                    
                    <ListBox Name="LstRecoveryCodes" Height="100" Background="#151515" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding}" Foreground="#F1FA8C" FontFamily="Consolas" VerticalAlignment="Center" Grid.Column="0"/>
                                    <Button Content="✕" Background="Transparent" Foreground="#FF5555" Padding="5" Grid.Column="1" Click="OnRemoveCodeClick"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
        
        <Grid Grid.Row="1" ColumnDefinitions="*, *">
            <Button Grid.Column="0" Name="BtnCancel" Content="İptal" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="40" Background="#333333" Foreground="White" CornerRadius="5" Click="OnCancelClick"/>
            <Button Grid.Column="1" Name="BtnSave" Content="Kaydet" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="40" Background="#2A7AD2" Foreground="White" FontWeight="Bold" CornerRadius="5" Click="OnSaveClick"/>
        </Grid>
        
    </Grid>
</Window>