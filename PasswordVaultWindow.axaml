<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Vault"
        xmlns:converters="clr-namespace:Vault.Converters"
        x:Class="Vault.PasswordVaultWindow"
        Title="Password Vault"
        Width="1350" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    
    <Window.Resources>
        <converters:EmailUsernameConverter x:Key="EmailUsernameConverter"/>
    </Window.Resources>
    
    <Grid Margin="20" RowDefinitions="Auto, Auto, Auto, *, Auto">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto, Auto, Auto" Margin="0,0,0,15">
            <TextBox Name="TxtSearch" 
                     PlaceholderText="Site, e-posta veya kullanıcı adı ara..." 
                     FontSize="14"
                     Background="#2D2D2D"
                     Foreground="White"
                     BorderBrush="#444444"
                     CornerRadius="5"
                     Grid.Column="0"
                     Margin="0,0,10,0"/>
            <Button Name="BtnFilter" 
                    Content="Filtrele" 
                    Width="100" Height="35"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    Click="OnFilterClick"/>
            <Button Name="BtnExport"
                    Content="Dışa Aktar"
                    Height="35"
                    Padding="12,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="2"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    ToolTip.Tip="Kasayı JSON olarak dışa aktar"
                    Click="OnExportClick"/>
            <Button Name="BtnImport"
                    Content="İçe Aktar"
                    Height="35"
                    Padding="12,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="3"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    ToolTip.Tip="JSON dosyasından şifreleri içe aktar"
                    Click="OnImportClick"/>
            <Button Name="BtnChangePassword"
                    Content="🔑"
                    Width="35" Height="35"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="4"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    ToolTip.Tip="Kasa Şifresini Değiştir"
                    Click="OnChangePasswordClick"/>
            <Button Name="BtnLock"
                    Content="🔒"
                    Width="35" Height="35"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="5"
                    Cursor="Hand" ToolTip.Tip="Kasayı Kilitle"
                    Click="OnLockClick">

                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#333333"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#222222"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </Button.Styles>

            </Button>
        </Grid>

        <Button Name="BtnAddNew" 
                Content="+ Yeni Şifre Ekle" 
                Background="#2A7AD2"
                Foreground="White"
                FontWeight="SemiBold"
                Padding="15,8"
                CornerRadius="5"
                Grid.Row="1"
                Margin="0,0,0,20"
                Click="OnAddNewClick"/>

        <Grid Grid.Row="2" ColumnDefinitions="50, 2*, 3*, 2*, 2*, 110" Margin="10,0,10,5">
            <TextBlock Text="#" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="0"/>
            <TextBlock Text="SİTE / UYGULAMA" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="1"/>
            <TextBlock Text="E-POSTA | KULLANICI ADI" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="2"/>
            <TextBlock Text="ŞİFRE" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="3"/>
            <TextBlock Text="KURTARMA KODLARI" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="4"/>
            <TextBlock Text="İŞLEMLER" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="5" HorizontalAlignment="Center"/>
        </Grid>

        <ListBox Name="LstPasswords" 
                 Grid.Row="3" 
                 Background="#252526" 
                 BorderBrush="#333333"
                 BorderThickness="1"
                 CornerRadius="5">
            
            <ListBox.Styles>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="#2A7AD2"/>
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#3D8AE5"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#2D2D30"/>
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False" x:DataType="local:Models.PasswordEntry">
                    <Grid ColumnDefinitions="50, 2*, 3*, 2*, 2*, 110" VerticalAlignment="Center" Margin="0,5">
                        
                        <SelectableTextBlock Text="{Binding Id}" 
                                             Foreground="#666666" 
                                             FontSize="12" 
                                             FontFamily="Consolas" 
                                             VerticalAlignment="Center" 
                                             Grid.Column="0"/>
                        
                        <TextBlock Text="{Binding Site}" Foreground="#E0E0E0" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Column="1"/>
                        
                        <SelectableTextBlock Foreground="#A0A0A0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Grid.Column="2">
                            <SelectableTextBlock.Text>
                                <MultiBinding Converter="{StaticResource EmailUsernameConverter}">
                                    <Binding Path="Email"/>
                                    <Binding Path="Username"/>
                                </MultiBinding>
                            </SelectableTextBlock.Text>
                        </SelectableTextBlock>
                        
                        <Panel Grid.Column="3" VerticalAlignment="Center">
                            <TextBlock Text="••••••••" 
                                       Foreground="#666666" 
                                       VerticalAlignment="Center" 
                                       IsVisible="{Binding !#BtnToggleReveal.IsChecked}"/>
                            <SelectableTextBlock Text="{Binding Password}" 
                                                 Foreground="#E0E0E0" 
                                                 VerticalAlignment="Center" 
                                                 TextTrimming="CharacterEllipsis"
                                                 IsVisible="{Binding #BtnToggleReveal.IsChecked}"/>
                        </Panel>
                        
                        <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,2">
                            <TextBlock Text="•••• ••••" Foreground="#555555" FontSize="12" IsVisible="{Binding !#BtnToggleReveal.IsChecked}"/>
                            <ItemsControl ItemsSource="{Binding RecoveryCodes}" IsVisible="{Binding #BtnToggleReveal.IsChecked}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <SelectableTextBlock Text="{Binding}" Foreground="#F1FA8C" FontSize="12" FontFamily="Consolas, Courier New" Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Grid.Column="5">
                            <ToggleButton Name="BtnToggleReveal" Content="👁️" Background="Transparent" Padding="5" ToolTip.Tip="Göster / Gizle"/>
                            <Button Content="📋" Background="Transparent" Padding="5" ToolTip.Tip="Şifreyi Kopyala" Click="OnCopyPasswordClick"/>
                            <Button Content="✏️" Background="Transparent" Padding="5" ToolTip.Tip="Kaydı Düzenle" Click="OnEditPasswordEntryClick"/>
                        </StackPanel>
                        
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4" Margin="0,10,0,0" Spacing="6">
            <ProgressBar Name="PgrSaving"
                         IsIndeterminate="True"
                         IsVisible="False"
                         Height="3"
                         Foreground="#2A7AD2"
                         Background="#333333"/>
            <TextBlock Name="LblSaving"
                       Text="Kaydediliyor, lütfen bekleyin..."
                       IsVisible="False"
                       HorizontalAlignment="Center"
                       Foreground="#888888"
                       FontSize="12"/>
            <TextBlock Name="TxtSaveError"
                       IsVisible="False"
                       HorizontalAlignment="Center"
                       Foreground="#E05555"
                       FontSize="12"/>
            <TextBlock Name="TxtExportStatus"
                       IsVisible="False"
                       HorizontalAlignment="Center"
                       Foreground="#55C070"
                       FontSize="12"/>
        </StackPanel>
        
    </Grid>
</Window>