<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vault.ChangeVaultPasswordWindow"
        Title="Kasa Şifresini Değiştir"
        Width="380" Height="260"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E1E">

    <Grid Margin="20" RowDefinitions="Auto, Auto, Auto, Auto, *, Auto">

        <TextBlock Text="Yeni Kasa Şifresi" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,15" Grid.Row="0"/>

        <TextBox Name="TxtNewPassword"
                 PasswordChar="●"
                 PlaceholderText="Yeni şifre"
                 Background="#2D2D2D"
                 Foreground="White"
                 BorderBrush="#444444"
                 CornerRadius="5"
                 Margin="0,0,0,10"
                 Grid.Row="1"/>

        <TextBox Name="TxtConfirmPassword"
                 PasswordChar="●"
                 PlaceholderText="Yeni şifre (tekrar)"
                 Background="#2D2D2D"
                 Foreground="White"
                 BorderBrush="#444444"
                 CornerRadius="5"
                 Margin="0,0,0,10"
                 Grid.Row="2"/>

        <TextBlock Name="TxtError"
                   Text=""
                   Foreground="#E05555"
                   FontSize="12"
                   TextWrapping="Wrap"
                   IsVisible="False"
                   Grid.Row="3"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Grid.Row="5">
            <Button Content="İptal"
                    Background="#333333"
                    Foreground="White"
                    Padding="15,8"
                    CornerRadius="5"
                    Click="OnCancelClick"/>
            <Button Content="Değiştir"
                    Background="#2A7AD2"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Padding="15,8"
                    CornerRadius="5"
                    Click="OnSaveClick"/>
        </StackPanel>

    </Grid>
</Window>