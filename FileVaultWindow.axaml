<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Vault"
        xmlns:converters="clr-namespace:Vault.Converters"
        x:Class="Vault.FileVaultWindow"
        Title="File Vault"
        Width="1350" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    
    <Window.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
    </Window.Resources>
    
    <Grid Margin="20" RowDefinitions="Auto, Auto, Auto, *, Auto">
        
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto" Margin="0,0,0,15">
            <TextBox Name="TxtSearch" 
                     PlaceholderText="Dosya adı ara..." 
                     FontSize="14"
                     Background="#2D2D2D"
                     Foreground="White"
                     BorderBrush="#444444"
                     CornerRadius="5"
                     Grid.Column="0"
                     Margin="0,0,10,0"/>
            <Button Name="BtnFilter" 
                    Content="Filtrele" 
                    Width="100" Height="35"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    Click="OnFilterClick"/>
            <Button Name="BtnChangePassword"
                    Content="🔑"
                    Width="35" Height="35"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="2"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    ToolTip.Tip="Kasa Şifresini Değiştir"
                    Click="OnChangePasswordClick"/>
            <Button Name="BtnLock"
                    Content="🔒"
                    Width="35" Height="35"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#333333"
                    Foreground="White"
                    CornerRadius="5"
                    Grid.Column="3"
                    Cursor="Hand" ToolTip.Tip="Kasayı Kilitle"
                    Click="OnLockClick">
    
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#333333"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#222222"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </Button.Styles>
    
            </Button>
        </Grid>

        <Button Name="BtnAddNew" 
                Content="+ Yeni Dosya Yükle" 
                Background="#2A7AD2"
                Foreground="White"
                FontWeight="SemiBold"
                Padding="15,8"
                CornerRadius="5"
                Grid.Row="1"
                Margin="0,0,0,20"
                Click="OnAddNewClick"/>

        <Grid Grid.Row="2" ColumnDefinitions="50, 4*, 1*, 2*, 2*, 110" Margin="10,0,10,5">
            <TextBlock Text="#" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="0"/>
            <TextBlock Text="DOSYA ADI" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="1"/>
            <TextBlock Text="DOSYA BOYUTU" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="2"/>
            <TextBlock Text="DOSYA TİPİ" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="3"/>
            <TextBlock Text="OLUŞTURULMA ZAMANI" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="4"/>
            <TextBlock Text="İŞLEMLER" Foreground="#888888" FontSize="12" FontWeight="Bold" Grid.Column="5" HorizontalAlignment="Center"/>
        </Grid>

        <ListBox Name="LstPasswords" 
                 Grid.Row="3" 
                 Background="#252526" 
                 BorderBrush="#333333"
                 BorderThickness="1"
                 CornerRadius="5">
            
            <ListBox.Styles>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="#2A7AD2"/>
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#3D8AE5"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#2D2D30"/>
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False" x:DataType="local:Models.FileLookupEntry">
                    <Grid ColumnDefinitions="50, 4*, 1*, 2*, 2*, 110" VerticalAlignment="Center" Margin="0,5">
                        
                        <TextBlock Text="{Binding Id}" Foreground="#E0E0E0" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Column="0"/>
                        
                        <TextBlock Text="{Binding OriginalName}" Foreground="#E0E0E0" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Column="1"/>
                        
                        <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" Foreground="#E0E0E0" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Column="2"/>
                        
                        <TextBlock Text="{Binding MimeType}" Foreground="#E0E0E0" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Column="3"/>
                        
                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" Foreground="#E0E0E0" VerticalAlignment="Center" FontWeight="SemiBold" Grid.Column="4"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5" Grid.Column="5">
                            <Button Background="Transparent" Padding="5" Cursor="Hand" ToolTip.Tip="Dosyayı İndir" Click="OnDownloadClick">
                                <PathIcon Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z"/>
                            </Button>

                            <Button Background="Transparent" Padding="5" Cursor="Hand" ToolTip.Tip="Dosyayı Sil" Click="OnDeleteClick">
                                <PathIcon Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                            </Button>
                        </StackPanel>
                        
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4" Margin="0,10,0,0" Spacing="6">
            <ProgressBar Name="PgrProgressBar"
                         IsIndeterminate="True"
                         IsVisible="False"
                         Height="3"
                         Foreground="#2A7AD2"
                         Background="#333333"/>
            <TextBlock Name="LblProgress"
                       Text=""
                       IsVisible="False"
                       HorizontalAlignment="Center"
                       Foreground="#888888"
                       FontSize="12"/>
            <TextBlock Name="TxtSaveError"
                       IsVisible="False"
                       HorizontalAlignment="Center"
                       Foreground="#E05555"
                       FontSize="12"/>
        </StackPanel>
        
    </Grid>
</Window>